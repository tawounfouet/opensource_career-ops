    "openai:tailor": "node scripts/js/openai-tailor.mjs",
    "eval:golden": "node scripts/js/eval-golden.mjs",
    "star": "node scripts/js/match-star.mjs",
    "archive": "node scripts/js/archive-posting.mjs",
    "prepare:application": "node scripts/js/prepare-application.mjs",
    "build:dashboard": "node scripts/js/build-dashboard.mjs",
    "serve:dashboard": "cd dashboard && go run . --path ..",
