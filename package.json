{
  "name": "career-ops",
  "version": "1.20.0",
  "description": "AI-powered job search pipeline — works with any AI coding CLI (Claude Code, OpenCode, Gemini, Codex, Qwen)",
  "private": true,
  "scripts": {
    "doctor": "node scripts/js/doctor.mjs",
    "or": "node scripts/js/openrouter-runner.mjs",
    "or:scan": "node scripts/js/openrouter-runner.mjs scan",
    "or:pipeline": "node scripts/js/openrouter-runner.mjs pipeline",
    "or:eval": "node scripts/js/openrouter-runner.mjs evaluate",
    "or:apply": "node scripts/js/openrouter-runner.mjs apply",
    "verify": "node scripts/js/verify-pipeline.mjs",
    "normalize": "node scripts/js/normalize-statuses.mjs",
