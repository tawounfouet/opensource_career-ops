{
  "name": "biomedical",
  "description": "Thème biomédical corporate — cyan technologique, bleu médical doux, grille stricte, accent color",
  "page": {
    "format": "A4",
    "orientation": "portrait",
    "width_mm": 210,
    "height_mm": 297
  },
  "layout": {
    "sidebar_ratio": 0.29,
    "main_ratio": 0.71,
    "header_height_ratio": 0.12,
    "content_height_ratio": 0.88
  },
  "colors": {
    "primary": "#0CC0DF",
    "primary_dark": "#0A9DBF",
    "primary_light": "#E8F7FB",
    "header_background": "#B2D5E8",
    "header_accent": "#8BBDD6",
    "surface": "#FFFFFF",
    "text_primary": "#1A1A2E",
    "text_secondary": "#4A4A68",
    "text_muted": "#7A7A98",
    "sidebar_heading": "#FFFFFF",
    "divider": "#D0D0E0",
    "divider_strong": "#1A1A2E",
    "accent": "#0CC0DF"
  },
  "typography": {
    "family": "Inter",
    "fallback": "sans-serif",
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "styles": ["regular", "bold", "italic"],
    "scale": {
      "name": { "size": "22pt", "weight": 700, "align": "center", "letter_spacing": "0.02em" },
      "job_title": { "size": "11.5pt", "weight": 600, "align": "center", "color": "#0A9DBF" },
      "objective": { "size": "8.5pt", "weight": 400, "align": "center" },
      "section_title": { "size": "11pt", "weight": 700, "transform": "uppercase", "letter_spacing": "0.06em" },
      "sidebar_title": { "size": "10pt", "weight": 700, "transform": "uppercase", "letter_spacing": "0.1em" },
      "entry_date": { "size": "8pt", "weight": 700, "color": "#0A9DBF", "transform": "uppercase", "letter_spacing": "0.04em" },
      "entry_title": { "size": "9.5pt", "weight": 700 },
      "entry_organization": { "size": "8.5pt", "style": "italic" },
      "body": { "size": "8.5pt", "weight": 400, "line_height": 1.3 },
      "sidebar_item": { "size": "8pt", "weight": 400 }
    }
  },
  "spacing": {
    "xs": "2px",
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "xl": "18px",
    "xxl": "24px"
  },
  "components": {
    "identity_banner": {
      "background": "linear-gradient(135deg, #B2D5E8 0%, #8BBDD6 100%)",
      "text_align": "center",
      "padding_top": "20px",
      "padding_bottom": "16px",
      "padding_horizontal": "24px",
      "bottom_accent": "linear-gradient(90deg, transparent, #0CC0DF, transparent)"
    },
    "sidebar": {
      "width": "29%",
      "background": "#0CC0DF",
      "padding": "22px 16px",
      "right_border": "3px solid gradient"
    },
    "section_heading": {
      "margin_bottom": "8px",
      "padding_bottom": "4px",
      "border_bottom": "2.5px solid #1A1A2E",
      "accent_bar": "4px x 14px #0CC0DF"
    },
    "experience_entry": {
      "border_left": "2px solid #D0D0E0",
      "dot": "6px circle #0CC0DF"
    },
    "qr_code": {
      "wrapper": "rgba(255,255,255,0.1) background",
      "width": "70px",
      "label": "LinkedIn uppercase"
    }
  },
  "icons": {
    "style": "inline-svg",
    "size": "12px",
    "stroke_width": 2,
    "color": "rgba(255,255,255,0.8)"
  },
  "rules": {
    "date_position": "separate_line_above_role",
    "role_weight": "bold",
    "organization_style": "italic",
    "missions": "bullet_list",
    "section_titles": "uppercase_with_accent_bar",
    "punctuation": "dash_before_bullet",
    "alignment": "left"
  }
}
